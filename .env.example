# 🤖 MS-DRIFT-26 | Institutional Environment Configuration
# Instructions: Copy this file to a new file named '.env' and fill in your credentials.

# --- [ CORE AI AUTHENTICATION ] ---
# Get your key from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_2_0_flash_key_here

# --- [ INSTITUTIONAL BROKER GATEWAY ] ---
# Replace with your actual Broker/Exchange credentials (e.g., Binance, IBKR, MT5)
BROKER_API_KEY=your_broker_api_key_here
BROKER_SECRET_KEY=your_broker_secret_here

# --- [ SYSTEM LATENCY & LOGGING ] ---
# Set to 'TRUE' to enable high-speed JSON audit trails
ENABLE_AUDIT_LOGGING=TRUE
SYSTEM_MODE=PRODUCTION # Options: DEVELOPMENT, PRODUCTION, BACKTEST

# --- [ RISK MANAGEMENT THRESHOLDS ] ---
# Minimum logic confidence required from Gemini before execution (0.0 to 1.0)
MIN_AI_CONFIDENCE_SCORE=0.85
MAX_POSITION_SIZE_PERCENT=0.02
